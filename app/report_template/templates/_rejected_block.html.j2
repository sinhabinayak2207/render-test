<section class="tender-section verdict-rejected">
  <h3 class="tender-heading">
    <span class="tender-idx">#{{ t_index }}</span>
    <span class="verdict-pill verdict-rejected">{{ t.verdict }}</span>
    <span class="tender-title">{{ t.title }}</span>
  </h3>

  <h4 class="sec">1. Basic Tender Information</h4>
  <table class="kv-table">
    <tr><th>Authority Issuing the Tender</th><td>{{ t.authority }}</td></tr>
    <tr><th>Portal Source</th><td>{{ t.portal }}</td></tr>
    <tr><th>Tender Reference Number</th><td>{{ t.reference_number }}</td></tr>
    <tr><th>Estimated Value</th><td>{{ t.estimated_value }}</td></tr>
    <tr><th>Pre-bid Meeting Date</th><td>{{ t.pre_bid_date }}</td></tr>
    <tr><th>Submission Date</th><td>{{ t.closing_date }}</td></tr>
    <tr><th>Tender Type</th><td>{{ t.tender_type }}{% if t.bid_eval == 'QC' %} — Quality-cum-Cost (QC){% elif t.bid_eval == 'LC' %} — Least-Cost (LC){% elif t.bid_eval == 'L1' %} — Lowest-Price (L1){% endif %}</td></tr>
  </table>

  <h4 class="sec">2. Keyword Match Activation</h4>
  <p class="narrative">
    The automated crawler flagged this tender because it contained a direct
    match with:
    <strong>
      {% if t.matched_keyword %}{{ t.matched_keyword }}{% else %}an internal scope keyword{% endif %}
    </strong>.
  </p>

  <h4 class="sec">3. Disqualification Triggers</h4>
  {% if t.disqualification_triggers %}
    {% for tg in t.disqualification_triggers %}
    <div class="trigger-block">
      <h5 class="trigger-name">{{ tg.name }}</h5>
      <p class="trigger-evidence">{{ tg.evidence }}</p>
    </div>
    {% endfor %}
  {% else %}
    <p>No specific triggers recorded — see fallback reasons below.</p>
    {% if t.reasons %}
      <ul>{% for r in t.reasons %}<li>{{ r }}</li>{% endfor %}</ul>
    {% endif %}
  {% endif %}

  <h4 class="sec">4. Business Logic Explanation</h4>
  {% if t.business_logic_explanation %}
    <p class="narrative">{{ t.business_logic_explanation }}</p>
  {% else %}
    <p>
      The scanner matched a watched keyword but on closer inspection the core
      scope falls outside CSDirekt's service profile (museum AV / immersive
      cultural media / heritage projection / exhibition design).
    </p>
  {% endif %}

  <h4 class="sec">5. Eligibility Assessment — What Would Make CS Direkt Eligible</h4>
  {% if t.gaps %}
    <p><strong>Gaps that currently make CS Direkt ineligible:</strong></p>
    <ul>{% for g in t.gaps %}<li>{{ g }}</li>{% endfor %}</ul>
  {% endif %}
  {% if t.requirements %}
    <p><strong>Tender requirements — fulfil these to qualify:</strong></p>
    <ul>{% for r in t.requirements %}<li>{{ r }}</li>{% endfor %}</ul>
  {% endif %}
  {% if not t.gaps and not t.requirements %}
    <p class="narrative">This tender falls outside CS Direkt's core service profile — there is no realistic path to eligibility based on the capabilities in CS Direkt's documents.</p>
  {% endif %}

  {% if t.pre_bid_queries %}
  <h4 class="sec">6. Pre-bid Queries (to widen eligibility, if defensible)</h4>
    {% for q in t.pre_bid_queries %}
    <div class="prebid-card">
      <p class="prebid-head">
        <span class="prebid-pri prebid-{{ 'crit' if (q.priority|lower) == 'critical' else 'imp' }}">{{ q.priority }}</span>
        <strong>Clause Reference:</strong> {{ q.clause_reference }}
      </p>
      <table class="kv-table">
        <tr><th>Existing Requirement</th><td>{{ q.existing_requirement }}</td></tr>
        {% if q.observation %}<tr><th>Observation / Concern</th><td>{{ q.observation }}</td></tr>{% endif %}
        <tr><th>Recommended Pre-bid Question</th><td>{{ q.question }}</td></tr>
        {% if q.strategic_objective %}<tr><th>Strategic Objective</th><td>{{ q.strategic_objective }}</td></tr>{% endif %}
        {% if q.expected_benefit %}<tr><th>Expected Benefit if Accepted</th><td>{{ q.expected_benefit }}</td></tr>{% endif %}
      </table>
    </div>
    {% endfor %}
  {% endif %}

  {% if not t_is_last %}<hr class="tender-sep">{% endif %}
</section>
